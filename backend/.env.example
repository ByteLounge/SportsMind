# Server
PORT=3001
NODE_ENV=development

# Scraping behavior
FETCH_TIMEOUT_MS=12000
FETCH_RETRIES=2
FETCH_RETRY_DELAY_MS=800
CONCURRENCY_CAP=2

# Cache TTLs (seconds)
CACHE_TTL_LIVE_LIST=20
CACHE_TTL_MATCH_LIVE=15
CACHE_TTL_SCORECARD=15
CACHE_TTL_COMMENTARY=12
CACHE_TTL_SQUADS=3600
CACHE_TTL_POINTS_TABLE=3600
CACHE_TTL_HIGHLIGHTS=600

# Playwright fallback (set to "true" to enable — requires playwright installed)
USE_PLAYWRIGHT_FALLBACK=false

# Logging
LOG_LEVEL=info
LOG_SELECTOR_MISSES=false

# CORS origins (comma-separated for multiple)
CORS_ORIGIN=https://sports-mind.vercel.app,http://localhost:5173

# Parser version — bump when selectors change
PARSER_VERSION=1.0.0
