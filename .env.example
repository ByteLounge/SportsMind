# --- FRONTEND (SportsMind AI) ---
VITE_GEMINI_API_KEY=""
VITE_GROQ_API_KEY=""
VITE_ELEVENLABS_API_KEY=""
VITE_FOOTBALL_API_KEY=""
VITE_CRICKET_API_KEY=""
VITE_NEWS_API_KEY=""
VITE_RAPIDAPI_KEY=""
VITE_BACKEND_URL="http://localhost:3001"

# --- BACKEND (CricketScrap) ---
PORT=3001
NODE_ENV=development

# Scraping behavior
FETCH_TIMEOUT_MS=12000
FETCH_RETRIES=2
FETCH_RETRY_DELAY_MS=800
CONCURRENCY_CAP=2

# Cache TTLs (seconds)
CACHE_TTL_LIVE_LIST=20
CACHE_TTL_MATCH_LIVE=15
CACHE_TTL_SCORECARD=15
CACHE_TTL_COMMENTARY=12
CACHE_TTL_SQUADS=3600
CACHE_TTL_POINTS_TABLE=3600
CACHE_TTL_HIGHLIGHTS=600

# Playwright fallback
USE_PLAYWRIGHT_FALLBACK=false

# Logging
LOG_LEVEL=info
LOG_SELECTOR_MISSES=false

# CORS origins
CORS_ORIGIN=http://localhost:5173

# Parser version
PARSER_VERSION=1.0.0
